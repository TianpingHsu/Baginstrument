{
    "manifest_version": 3,
    "name": "Baginstrument",
    "description": "pick it",
    "version": "0.0.1",
    "icons": {
        "16": "logo/logo-16.png",
        "48": "logo/logo-48.png",
        "128": "logo/logo-128.png"
    },
    "options_page": "html/options.html",
    "action": {
        "default_title": "Baginstrument",
        "default_popup": "html/popup.html"
    },
    "permissions": [
        "contextMenus",
        "tabs",
        "notifications",
        "webRequest",
        "storage",
        "commands",
        "scripting"
    ],
    "host_permissions": [
        "*://*/*"
    ],
    "homepage_url": "https://nextjs.org/",
    "background": {
        "service_worker": "js/service-worker.js"
    },
    "content_scripts": [
        {
            "js": [
                "js/foreground.js"
            ],
            "matches": [
                "https://github.com/*"
            ]
        },
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "js/jquery-1.8.3.js",
                "js/content-script.js"
            ],
            "css": [
                "css/custom.css"
            ],
            "run_at": "document_start"
        },
        {
            "matches": [
                "*://*/*.png",
                "*://*/*.jpg",
                "*://*/*.gif",
                "*://*/*.bmp"
            ],
            "js": [
                "js/show-image-content-size.js"
            ]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["html/view.html", "css/view.css", "js/view.js"],
            "matches": ["<all_urls>"]
        }
    ],
    "commands": {
        "save-it-into-pocket": {
            "suggested_key": "Shift+Alt+S",
            "description": "save it"
        }
    },
    "omnibox": {
        "keyword": "pick"
    },
    "default_locale": "zh_CN",
    "devtools_page": "html/devtools.html",
    "chrome_url_overrides": {
        "newtab": "html/newtab.html"
    }
}
